# infra/keycloak/env/production.env
#
# Variable contract for keycloak-config-cli when applying realm.yaml in
# production (Azure, Ansible-driven — see ai-scripts/02c3-ansible.md).
#
# Replace <bff-prod-fqdn> with the production Azure FQDN once 02c2
# (Terraform) provisions the App Service / Front Door. DEMO_PASSWORD is
# injected by Ansible from the production vault — never committed here.
BFF_BASE_URL=https://<bff-prod-fqdn>
BFF_JWKS_URL=https://<bff-prod-fqdn>/.well-known/jwks.json

{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:api && vite",
    "dev:intg": "npm run generate:api && vite --mode local-intg",
    "build": "npm run generate:api && vue-tsc --noEmit && vite build",
    "build:intg": "npm run generate:api && vue-tsc --noEmit && vite build --mode local-intg",
    "build:no-codegen": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "generate:api": "openapi-generator-cli generate -i ../contracts/openapi.yaml -c ../contracts/codegen-typescript-axios.json -o src/services/api-client/generated",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.15.2",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}

# infra/keycloak/env/local-intg.env
#
# Variable contract for keycloak-config-cli when applying realm.yaml in the
# local-intg environment (docker compose up).
#
# - BFF_BASE_URL : public URL the browser uses to reach the BFF in local-intg.
#                  After the SCG migration the SPA is served by Vite at :5173
#                  (not by the BFF), so the OAuth2 callback and the
#                  post-logout landing both have to come back to Vite. Vite
#                  already proxies /login, /oauth2, /logout and /api to the
#                  BFF, so Keycloak's registered redirect URIs and
#                  post-logout URI all point at :5173.
# - BFF_JWKS_URL : URL Keycloak (running in the same Docker network) uses to
#                  fetch the BFF's public JWKS — MUST be the internal Docker
#                  DNS name, not localhost (which would resolve inside the
#                  Keycloak container, not on the host).
# - DEMO_PASSWORD: taken from the shell env / .env (default demo123 in
#                  local-intg; see docker-compose.yml keycloak-config service).
BFF_BASE_URL=http://localhost:5173
BFF_JWKS_URL=http://bff:8080/.well-known/jwks.json

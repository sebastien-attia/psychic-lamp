# infra/keycloak/env/local-intg.env
#
# Variable contract for keycloak-config-cli when applying realm.yaml in the
# local-intg environment (docker compose up).
#
# - BFF_BASE_URL : public URL the browser uses to reach the BFF (host port).
# - BFF_JWKS_URL : URL Keycloak (running in the same Docker network) uses to
#                  fetch the BFF's public JWKS — MUST be the internal Docker
#                  DNS name, not localhost (which would resolve inside the
#                  Keycloak container, not on the host).
# - DEMO_PASSWORD: taken from the shell env / .env (default demo123; see
#                  the keycloak-config service in docker-compose.yml). The
#                  same value is pinned in the staging/production deploy
#                  workflows — see realm.users.demo.yaml SECURITY NOTE.
BFF_BASE_URL=http://localhost:8080
BFF_JWKS_URL=http://bff:8080/.well-known/jwks.json

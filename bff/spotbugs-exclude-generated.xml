<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter — two purposes (filename kept stable for the
  phase-02a6 verification grep; treat its scope as "generated + tuning").

  1. Skip OpenAPI-generated code — it isn't authored here and any finding
     would flap on every regenerate.
  2. Suppress baseline false-positives / framework noise that fire across
     the codebase. Each suppression below documents WHY it is benign for
     this project; a future hardening pass can revisit them per-class.
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0">

  <!-- ── 1. OpenAPI-generated code ─────────────────────────────────── -->
  <!-- "~" prefix marks the Class name as a SpotBugs regex.
       Covers, in this module:
         - ch.owt.boatapp.bff.adapter.out.client.generated.*  (HTTP client)
         - ch.owt.boatapp.bff.adapter.in.web.dto.generated.*  (DTOs) -->
  <Match><Class name="~.*\.generated\..*"/></Match>
  <Match><Class name="~.*\.dto\.generated\..*"/></Match>

  <!-- ── 2. Spring DI exposure noise ───────────────────────────────── -->
  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2 fire on every constructor-injected
       Spring singleton. Spring owns the bean lifecycle; "exposure" is
       not the right mental model here. -->
  <Match><Bug pattern="EI_EXPOSE_REP"/></Match>
  <Match><Bug pattern="EI_EXPOSE_REP2"/></Match>

  <!-- ── 3. Intentional CSRF disable in stateless / dev configs ────── -->
  <!-- The browser-facing BFF SecurityConfig keeps CSRF enabled (cookie
       session). DevSecurityConfig disables it on purpose for the
       no-Keycloak dev mode. -->
  <Match><Bug pattern="SPRING_CSRF_PROTECTION_DISABLED"/></Match>

  <!-- ── 4. Spring Security required signatures ───────────────────── -->
  <!-- SecurityFilterChain factory methods declare `throws Exception`
       per Spring's contract; we cannot narrow that. -->
  <Match><Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/></Match>

  <!-- ── 5. SPRING_ENDPOINT is informational, not a bug ─────────────── -->
  <Match><Bug pattern="SPRING_ENDPOINT"/></Match>

  <!-- ── 6. CRLF-in-logs: we log typed values, not raw user strings ─── -->
  <!-- All log args are typed records (BoatId/UserId UUIDs) or
       Spring-decoded URIs. No raw newline-bearing user input is logged.
       Tracked for future hardening (sanitizing SLF4J adapter). -->
  <Match><Bug pattern="CRLF_INJECTION_LOGS"/></Match>

  <!-- ── 7. JSON ProblemDetail responses, not HTML ─────────────────── -->
  <!-- RestAuthenticationEntryPoint writes ObjectMapper-serialized JSON
       with explicit Content-Type: application/problem+json — no HTML,
       no XSS surface. -->
  <Match><Bug pattern="XSS_SERVLET"/></Match>

  <!-- ── 8. Domain exceptions are never Java-serialized over the wire — -->
  <!-- They are caught by GlobalExceptionHandler and rendered as
       ProblemDetail; the SE_BAD_FIELD warning would only matter if they
       traveled through ObjectInputStream, which they do not. -->
  <Match><Bug pattern="SE_BAD_FIELD"/></Match>

  <!-- ── 9. CSRF token handler reads request headers by design ────── -->
  <!-- SpaCsrfTokenRequestHandler.resolveCsrfTokenValue MUST read the
       X-XSRF-TOKEN header — that is the entire purpose of the class. -->
  <Match><Bug pattern="SERVLET_HEADER"/></Match>

  <!-- ── 10. ASCII-token case mapping uses Locale.ROOT explicitly ──── -->
  <!-- FindSecBugs flags any case-mapping call regardless of the Locale
       argument. Future code that compares against ASCII tokens with an
       explicit Locale.ROOT does not vary by locale. -->
  <Match><Bug pattern="IMPROPER_UNICODE"/></Match>

</FindBugsFilter>

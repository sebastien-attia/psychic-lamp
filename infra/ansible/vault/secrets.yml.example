---
# infra/ansible/vault/secrets.yml.example
#
# Copy this file to vault/secrets.yml and encrypt with:
#
#   ansible-vault encrypt vault/secrets.yml
#
# DO NOT commit vault/secrets.yml in plaintext. The verifier
# (ai-scripts/checks/02c3/run.sh) refuses any committed playbook or role
# whose YAML contains a literal `password:` / `secret:` value not behind
# `vault_*` or `{{ ... }}`.
#
# ── What lives here vs. in Azure Key Vault ───────────────────────────────
# The vault file holds secrets that are INPUTS to the deployment process —
# values Ansible needs before it can talk to anything else (in particular,
# the per-DB role passwords used by bootstrap-db-roles.yml when first
# creating those roles, which then become the values stored in Key Vault).
#
# Application-runtime secrets (postgres-admin-password, bff-db-password,
# business-db-password, keycloak-db-password, bff-signing-key) are read at
# runtime from Azure Key Vault by roles/app-config/tasks/read-secrets.yml.
# Do NOT duplicate them here.
#
# ── Required keys ────────────────────────────────────────────────────────

# Per-DB role passwords (used by bootstrap-db-roles.yml to create the roles
# AND to populate the matching Key Vault secrets via Terraform). Generate
# fresh, high-entropy values per environment.
vault_bff_db_password: "REPLACE_ME"
vault_business_db_password: "REPLACE_ME"
vault_keycloak_db_password: "REPLACE_ME"

# Demo seed user password — only consulted when deploy_demo_user is true
# (staging only). Leave blank in production.
vault_demo_password: ""

# ── Operating notes ──────────────────────────────────────────────────────
# • Encrypted file is decrypted at playbook runtime via:
#     ansible-playbook --vault-password-file <pwfile> ...
#   On CI runners, set ANSIBLE_VAULT_PASSWORD_FILE in the job environment.
#
# • Rotate by re-encrypting with a new key and re-running deploy.yml. The
#   new vault values must already be present in Key Vault (Terraform-managed)
#   before the next bootstrap-db-roles run, or the role passwords will drift
#   from what the Container Apps inject.

# infra/keycloak/env/production.env
#
# Variable contract for keycloak-config-cli when applying realm.yaml in
# production. Ansible was removed; the values are now resolved inline by
# .github/workflows/deploy-production.yml (see the `keycloak-config` job),
# which reads the public BFF FQDN from the terraform outputs and pins
# DEMO_PASSWORD as a literal (intentional non-secret — see the SECURITY
# NOTE at the top of infra/keycloak/realm.users.demo.yaml).
#
# This file is retained as a reference contract; the workflow does not
# actually load it.
BFF_BASE_URL=https://<bff-prod-fqdn>
BFF_JWKS_URL=https://<bff-prod-fqdn>/.well-known/jwks.json

# infra/keycloak/env/staging.env
#
# Variable contract for keycloak-config-cli when applying realm.yaml in
# staging (Azure, Ansible-driven — see ai-scripts/02c3-ansible.md).
#
# Replace <bff-staging-fqdn> with the public Azure FQDN once 02c2 (Terraform)
# provisions the App Service / Front Door. DEMO_PASSWORD is injected by
# Ansible from the staging vault — never committed here.
BFF_BASE_URL=https://<bff-staging-fqdn>
BFF_JWKS_URL=https://<bff-staging-fqdn>/.well-known/jwks.json
